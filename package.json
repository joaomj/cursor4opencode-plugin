{
  "name": "cursor4opencode-plugin",
  "version": "1.0.0",
  "description": "OpenCode plugin that delegates tasks to Cursor Agent through the Cursor TypeScript SDK.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "keywords": [
    "opencode",
    "cursor",
    "cursor-agent",
    "cursor-sdk",
    "composer",
    "plugin",
    "opencode-tool"
  ],
  "license": "MIT",
  "author": {
    "name": "cursor4opencode-plugin contributors"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaomj/cursor4opencode-plugin.git"
  },
  "homepage": "https://github.com/joaomj/cursor4opencode-plugin#readme",
  "bugs": {
    "url": "https://github.com/joaomj/cursor4opencode-plugin/issues"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.17",
    "@opencode-ai/plugin": "^1.15.13"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "src/"
  ]
}
